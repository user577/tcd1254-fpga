## colorlight_i9.lpf — Pin constraints for Colorlight i9 v7.2
## FPGA: LFE5U-45F-6BG381C
##
## Pin mapping from SODIMM-200P connector (wuxx/Colorlight-FPGA-Projects).
## VERIFY against your ext board wiring before connecting hardware!

## ---- 25 MHz Oscillator ----
LOCATE COMP "CLK_25M" SITE "P3";
IOBUF  PORT "CLK_25M" IO_TYPE=LVCMOS33;
FREQUENCY PORT "CLK_25M" 25 MHZ;

## ---- ADC Data D[7:0] — SODIMM lower GPIO bank ----
LOCATE COMP "ADC_D0"  SITE "C4";   # SODIMM 131
LOCATE COMP "ADC_D1"  SITE "B4";   # SODIMM 133
LOCATE COMP "ADC_D2"  SITE "A3";   # SODIMM 139
LOCATE COMP "ADC_D3"  SITE "F5";   # SODIMM 120
LOCATE COMP "ADC_D4"  SITE "E4";   # SODIMM 128
LOCATE COMP "ADC_D5"  SITE "A2";   # SODIMM 154
LOCATE COMP "ADC_D6"  SITE "F4";   # SODIMM 126
LOCATE COMP "ADC_D7"  SITE "E1";   # SODIMM 153

IOBUF  PORT "ADC_D0"  IO_TYPE=LVCMOS33;
IOBUF  PORT "ADC_D1"  IO_TYPE=LVCMOS33;
IOBUF  PORT "ADC_D2"  IO_TYPE=LVCMOS33;
IOBUF  PORT "ADC_D3"  IO_TYPE=LVCMOS33;
IOBUF  PORT "ADC_D4"  IO_TYPE=LVCMOS33;
IOBUF  PORT "ADC_D5"  IO_TYPE=LVCMOS33;
IOBUF  PORT "ADC_D6"  IO_TYPE=LVCMOS33;
IOBUF  PORT "ADC_D7"  IO_TYPE=LVCMOS33;

## ---- ADC Data D[11:8] + Control Outputs — SODIMM upper GPIO bank ----
LOCATE COMP "ADC_D8"      SITE "M3";   # SODIMM 64
LOCATE COMP "ADC_D9"      SITE "N2";   # SODIMM 58  (was L2, but L2 = LED)
LOCATE COMP "ADC_D10"     SITE "T2";   # SODIMM 62  (was L3, doesn't exist)
LOCATE COMP "ADC_D11"     SITE "N4";   # SODIMM 70
LOCATE COMP "ADC_CLK_PIN" SITE "N3";   # SODIMM 60 — clock to AD9226
LOCATE COMP "FM_PIN"      SITE "M4";   # SODIMM 72 — fM to 74HCT04
LOCATE COMP "SH_PIN"      SITE "L4";   # SODIMM 74 — SH to 74HCT04
LOCATE COMP "ICG_PIN"     SITE "K5";   # SODIMM 150 — ICG to 74HCT04

IOBUF  PORT "ADC_D8"      IO_TYPE=LVCMOS33;
IOBUF  PORT "ADC_D9"      IO_TYPE=LVCMOS33;
IOBUF  PORT "ADC_D10"     IO_TYPE=LVCMOS33;
IOBUF  PORT "ADC_D11"     IO_TYPE=LVCMOS33;
IOBUF  PORT "ADC_CLK_PIN" IO_TYPE=LVCMOS33;
IOBUF  PORT "FM_PIN"      IO_TYPE=LVCMOS33;
IOBUF  PORT "SH_PIN"      IO_TYPE=LVCMOS33;
IOBUF  PORT "ICG_PIN"     IO_TYPE=LVCMOS33;

## ---- UART — SODIMM lower GPIO bank ----
LOCATE COMP "UART_TX" SITE "D1";   # SODIMM 149 — FPGA → host
LOCATE COMP "UART_RX" SITE "E2";   # SODIMM 151 — host → FPGA

IOBUF  PORT "UART_TX" IO_TYPE=LVCMOS33;
IOBUF  PORT "UART_RX" IO_TYPE=LVCMOS33 PULLMODE=UP;

## ---- Flash Lamp GPIO — J3 spare pins ----
## Active-high outputs to MOSFET drivers for xenon/LED flash lamps.
## VERIFY pin assignments against your J3 breakout wiring!
LOCATE COMP "FLASH_0" SITE "C1";   # J3_B0  — Flash 0 (top, 0 deg)
LOCATE COMP "FLASH_1" SITE "B1";   # J3_R1  — Flash 1 (angled, 45 deg)
LOCATE COMP "FLASH_2" SITE "D3";   # J3_G1  — Flash 2 (side, 90 deg)
LOCATE COMP "FLASH_3" SITE "C2";   # J3_B1  — Flash 3 (back, 135 deg)

IOBUF  PORT "FLASH_0" IO_TYPE=LVCMOS33 DRIVE=8;
IOBUF  PORT "FLASH_1" IO_TYPE=LVCMOS33 DRIVE=8;
IOBUF  PORT "FLASH_2" IO_TYPE=LVCMOS33 DRIVE=8;
IOBUF  PORT "FLASH_3" IO_TYPE=LVCMOS33 DRIVE=8;

## ---- Onboard LED ----
## LED D2 is on L2 (shared with SODIMM pin 41).
## Not used in this design (ADC uses all available connector groups).
## LOCATE COMP "LED" SITE "L2";
## IOBUF  PORT "LED" IO_TYPE=LVCMOS33;
